# Copy this file to `.env` and fill in your real values.
# cp .env.example .env

# === OpenAI API ===
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: override base URL (e.g. for Azure / proxy / OpenRouter)
OPENAI_BASE_URL=https://api.openai.com/v1
# Optional: organization / project id
# OPENAI_ORG_ID=
# OPENAI_PROJECT_ID=

# === Deep Research model ===
# Available: o3-deep-research, o4-mini-deep-research
OPENAI_DEEP_RESEARCH_MODEL=o4-mini-deep-research

# === Optional behavior knobs ===
# Max background polling time in seconds (deep research can take 5-30 min)
DEEP_RESEARCH_TIMEOUT=1800
# Whether to enable the web_search_preview tool (true/false)
DEEP_RESEARCH_WEB_SEARCH=true
# Whether to enable the code_interpreter tool (true/false)
DEEP_RESEARCH_CODE_INTERPRETER=true
